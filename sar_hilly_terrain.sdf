    <model name="tree_08_can"><static>true</static><pose>-25 10 5.2 0 0 0</pose><link name="l"><visual name="v"><geometry><cylinder><radius>2.5</radius><length>5.5</length></cylinder></geometry><material><ambient>0.10 0.24 0.09 1</ambient><diffuse>0.12 0.28 0.11 1</diffuse></material></visual></link></model>

    <model name="tree_09"><static>true</static><pose>18 -22 4 0 0 0</pose><link name="trunk"><visual name="v"><geometry><cylinder><radius>0.19</radius><length>3.6</length></cylinder></geometry><material><ambient>0.28 0.18 0.08 1</ambient><diffuse>0.32 0.20 0.10 1</diffuse></material></visual></link></model>
