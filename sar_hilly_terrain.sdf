    <model name="tree_04_c2"><static>true</static><pose>-18 28 10.8 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><cylinder><radius>1.8</radius><length>2.4</length></cylinder></geometry><material><ambient>0.13 0.28 0.11 1</ambient><diffuse>0.15 0.33 0.13 1</diffuse></material></visual></link></model>
    <model name="tree_04_c3"><static>true</static><pose>-18 28 12.5 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><cylinder><radius>0.9</radius><length>1.8</length></cylinder></geometry><material><ambient>0.16 0.32 0.14 1</ambient><diffuse>0.18 0.38 0.16 1</diffuse></material></visual></link></model>

    <!-- Tree 5 -->
    <model name="tree_05"><static>true</static><pose>28 -8 6 0 0 0</pose>
      <link name="trunk"><visual name="v"><geometry><cylinder><radius>0.19</radius><length>3.8</length></cylinder></geometry><material><ambient>0.28 0.18 0.08 1</ambient><diffuse>0.32 0.20 0.10 1</diffuse></material></visual><collision name="c"><geometry><cylinder><radius>0.19</radius><length>3.8</length></cylinder></geometry></collision></link></model>
    <model name="tree_05_c1"><static>true</static><pose>28 -8 10.0 0 0 0</pose>
