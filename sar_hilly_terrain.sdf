    <model name="tree_03_c1"><static>true</static><pose>15 44 16.7 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><cylinder><radius>2.0</radius><length>2.4</length></cylinder></geometry><material><ambient>0.11 0.27 0.10 1</ambient><diffuse>0.13 0.31 0.12 1</diffuse></material></visual></link></model>
    <model name="tree_03_c2"><static>true</static><pose>15 44 18.4 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><cylinder><radius>1.2</radius><length>1.8</length></cylinder></geometry><material><ambient>0.14 0.30 0.12 1</ambient><diffuse>0.16 0.35 0.14 1</diffuse></material></visual></link></model>

    <!-- Tree 4 -->
    <model name="tree_04"><static>true</static><pose>-18 28 5 0 0 0</pose>
      <link name="trunk"><visual name="v"><geometry><cylinder><radius>0.22</radius><length>4.5</length></cylinder></geometry><material><ambient>0.28 0.18 0.08 1</ambient><diffuse>0.32 0.20 0.10 1</diffuse></material></visual><collision name="c"><geometry><cylinder><radius>0.22</radius><length>4.5</length></cylinder></geometry></collision></link></model>
