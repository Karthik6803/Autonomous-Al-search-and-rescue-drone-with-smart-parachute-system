    <!-- ════════════════════════════════════════════════════════════════
         BOULDERS / ROCKS
         ════════════════════════════════════════════════════════════════ -->
    <model name="rock_1"><static>true</static><pose>12 48 14 0.3 0.1 0.5</pose>
