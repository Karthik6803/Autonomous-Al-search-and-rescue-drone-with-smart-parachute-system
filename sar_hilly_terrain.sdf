    <!-- ════════════════════════════════════════════════════════════════
         SURVIVOR MARKERS — 3 persons in orange hi-vis
         Each survivor has: body + arms + hi-vis vest + emergency tarp
         ════════════════════════════════════════════════════════════════ -->

    <!-- Survivor 1 — on hill slope, north area -->
    <model name="survivor_1_body">
      <static>true</static>
      <pose>10 38 8.2 0 0 0</pose>
      <link name="link">
        <visual name="torso">
          <geometry><cylinder><radius>0.22</radius><length>0.9</length></cylinder></geometry>
          <material><ambient>1.0 0.35 0.0 1</ambient><diffuse>1.0 0.40 0.0 1</diffuse></material>
        </visual>
        <collision name="c"><geometry><cylinder><radius>0.22</radius><length>0.9</length></cylinder></geometry></collision>
      </link>
    </model>
    <model name="survivor_1_head">
      <static>true</static>
      <pose>10 38 8.85 0 0 0</pose>
      <link name="link">
        <visual name="head">
          <geometry><sphere><radius>0.14</radius></sphere></geometry>
          <material><ambient>0.85 0.65 0.50 1</ambient><diffuse>0.85 0.65 0.50 1</diffuse></material>
        </visual>
      </link>
    </model>
    <!-- Orange emergency tarp next to survivor 1 -->
    <model name="survivor_1_tarp">
      <static>true</static>
      <pose>10.8 38 8.05 0 0 0.3</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>2.0 1.2 0.04</size></box></geometry>
          <material><ambient>1.0 0.20 0.0 1</ambient><diffuse>1.0 0.25 0.0 1</diffuse></material>
        </visual>
        <collision name="c"><geometry><box><size>2.0 1.2 0.04</size></box></geometry></collision>
      </link>
    </model>
    <!-- SOS sign -->
    <model name="survivor_1_sos">
      <static>true</static>
      <pose>9 36 8.01 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>3.0 1.0 0.02</size></box></geometry>
          <material><ambient>1.0 1.0 0.0 1</ambient><diffuse>1.0 1.0 0.0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Survivor 2 — valley floor, east area -->
    <model name="survivor_2_body">
      <static>true</static>
      <pose>35 -5 0.45 1.4 0 0</pose>
      <link name="link">
        <visual name="torso">
          <geometry><cylinder><radius>0.22</radius><length>0.9</length></cylinder></geometry>
          <material><ambient>1.0 0.35 0.0 1</ambient><diffuse>1.0 0.40 0.0 1</diffuse></material>
        </visual>
        <collision name="c"><geometry><cylinder><radius>0.22</radius><length>0.9</length></cylinder></geometry></collision>
      </link>
    </model>
    <model name="survivor_2_tarp">
      <static>true</static>
      <pose>36 -5 0.02 0 0 0.8</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>2.2 1.0 0.04</size></box></geometry>
          <material><ambient>1.0 0.20 0.0 1</ambient><diffuse>1.0 0.25 0.0 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="survivor_2_signal">
      <static>true</static>
      <pose>33 -6 0.01 0 0 1.2</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>2.5 0.8 0.02</size></box></geometry>
          <material><ambient>1.0 1.0 0.0 1</ambient><diffuse>1.0 1.0 0.0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Survivor 3 — west hill slope -->
    <model name="survivor_3_body">
      <static>true</static>
      <pose>-28 22 5.45 0 0 0</pose>
      <link name="link">
        <visual name="torso">
          <geometry><cylinder><radius>0.22</radius><length>0.9</length></cylinder></geometry>
          <material><ambient>1.0 0.35 0.0 1</ambient><diffuse>1.0 0.40 0.0 1</diffuse></material>
        </visual>
        <collision name="c"><geometry><cylinder><radius>0.22</radius><length>0.9</length></cylinder></geometry></collision>
      </link>
    </model>
    <model name="survivor_3_tarp">
      <static>true</static>
      <pose>-27.5 21 5.02 0 0 0.5</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>2.0 1.2 0.04</size></box></geometry>
          <material><ambient>1.0 0.20 0.0 1</ambient><diffuse>1.0 0.25 0.0 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="survivor_3_signal">
      <static>true</static>
      <pose>-30 23 5.01 0 0 0.2</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>2.5 0.8 0.02</size></box></geometry>
          <material><ambient>1.0 1.0 0.0 1</ambient><diffuse>1.0 1.0 0.0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ════════════════════════════════════════════════════════════════
         BASE CAMP — drone launch area
         ════════════════════════════════════════════════════════════════ -->
    <model name="base_camp_pad">
      <static>true</static>
      <pose>0 0 0.01 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><cylinder><radius>3.0</radius><length>0.02</length></cylinder></geometry>
          <material><ambient>0.6 0.6 0.6 1</ambient><diffuse>0.65 0.65 0.65 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="base_camp_H">
      <static>true</static>
      <pose>0 0 0.03 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>3.0 0.4 0.02</size></box></geometry>
          <material><ambient>1.0 0.9 0.0 1</ambient><diffuse>1.0 0.9 0.0 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="base_camp_tent">
      <static>true</static>
      <pose>-6 0 0.75 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>3.5 2.5 1.5</size></box></geometry>
          <material><ambient>0.2 0.5 0.8 1</ambient><diffuse>0.25 0.55 0.85 1</diffuse></material>
        </visual>
        <collision name="c"><geometry><box><size>3.5 2.5 1.5</size></box></geometry></collision>
      </link>
    </model>

    <!-- ════════════════════════════════════════════════════════════════
         IRIS DRONE with ArduPilot plugin
         ════════════════════════════════════════════════════════════════ -->
    <include>
      <uri>model://iris_with_ardupilot</uri>
      <name>iris_with_ardupilot</name>
      <pose>0 0 0.195 0 0 0</pose>
    </include>

    <!-- ════════════════════════════════════════════════════════════════
         PARACHUTE MODEL
         Starts hidden at z=-10. Bridge moves it above drone on fault.
         Orange canopy + 4 suspension lines + blue payload box
         ════════════════════════════════════════════════════════════════ -->
    <model name="parachute">
      <pose>0 0 -10 0 0 0</pose>
      <static>false</static>
      <link name="canopy">
        <inertial>
          <mass>0.15</mass>
          <inertia>
            <ixx>0.03</ixx><iyy>0.03</iyy><izz>0.03</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>

        <!-- Main dome -->
        <visual name="dome">
          <geometry><sphere><radius>1.1</radius></sphere></geometry>
          <material>
            <ambient>1.0 0.38 0.0 0.85</ambient>
            <diffuse>1.0 0.38 0.0 0.85</diffuse>
          </material>
        </visual>
        <collision name="dome_col">
          <geometry><sphere><radius>1.1</radius></sphere></geometry>
        </collision>

        <!-- Canopy panels — alternating colour stripes -->
        <visual name="stripe_1">
          <pose>0.5 0 -0.3 0 0.4 0</pose>
          <geometry><cylinder><radius>0.12</radius><length>1.8</length></cylinder></geometry>
          <material><ambient>1.0 1.0 1.0 0.7</ambient><diffuse>1.0 1.0 1.0 0.7</diffuse></material>
        </visual>
        <visual name="stripe_2">
          <pose>-0.5 0 -0.3 0 -0.4 0</pose>
          <geometry><cylinder><radius>0.12</radius><length>1.8</length></cylinder></geometry>
          <material><ambient>1.0 1.0 1.0 0.7</ambient><diffuse>1.0 1.0 1.0 0.7</diffuse></material>
        </visual>
        <visual name="stripe_3">
          <pose>0 0.5 -0.3 0.4 0 0</pose>
          <geometry><cylinder><radius>0.12</radius><length>1.8</length></cylinder></geometry>
          <material><ambient>1.0 1.0 1.0 0.7</ambient><diffuse>1.0 1.0 1.0 0.7</diffuse></material>
        </visual>

        <!-- Suspension lines -->
        <visual name="line_1">
          <pose>0.30 0.30 -0.85 0 0.32 0.785</pose>
          <geometry><cylinder><radius>0.007</radius><length>1.7</length></cylinder></geometry>
          <material><ambient>0.9 0.9 0.9 1</ambient><diffuse>0.9 0.9 0.9 1</diffuse></material>
        </visual>
        <visual name="line_2">
          <pose>-0.30 0.30 -0.85 0 -0.32 2.356</pose>
          <geometry><cylinder><radius>0.007</radius><length>1.7</length></cylinder></geometry>
          <material><ambient>0.9 0.9 0.9 1</ambient><diffuse>0.9 0.9 0.9 1</diffuse></material>
        </visual>
        <visual name="line_3">
          <pose>-0.30 -0.30 -0.85 0 0.32 3.927</pose>
          <geometry><cylinder><radius>0.007</radius><length>1.7</length></cylinder></geometry>
          <material><ambient>0.9 0.9 0.9 1</ambient><diffuse>0.9 0.9 0.9 1</diffuse></material>
        </visual>
        <visual name="line_4">
          <pose>0.30 -0.30 -0.85 0 -0.32 5.498</pose>
          <geometry><cylinder><radius>0.007</radius><length>1.7</length></cylinder></geometry>
          <material><ambient>0.9 0.9 0.9 1</ambient><diffuse>0.9 0.9 0.9 1</diffuse></material>
        </visual>

        <!-- Payload (drone hanging below) -->
        <visual name="payload">
          <pose>0 0 -1.9 0 0 0</pose>
          <geometry><box><size>0.38 0.38 0.16</size></box></geometry>
          <material><ambient>0.15 0.15 0.7 1</ambient><diffuse>0.15 0.15 0.7 1</diffuse></material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
