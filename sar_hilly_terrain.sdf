<?xml version="1.0" ?>
<!--
  SAR Hilly Terrain World — Gazebo Harmonic
  ==========================================
  Features:
    - Hilly terrain using heightmap mesh approach (box approximation for compatibility)
    - 25 pine trees scattered across hillsides
    - 5 boulders / rock clusters
    - 3 survivor markers (orange hi-vis rectangles) at different elevations
    - Iris drone with ArduPilot plugin
    - Parachute model (starts hidden at z=-10)
    - Atmospheric lighting (evening/golden hour)
    - Ground camp marker

  Launch:
    export GZ_SIM_RESOURCE_PATH=$HOME/cognitive_drone/ardupilot_gazebo/models:$HOME/cognitive_drone/worlds
    gz sim -v4 -r sar_hilly_terrain.sdf
-->
<sdf version="1.9">
  <world name="sar_hilly_terrain">

    <!-- ── Physics ─────────────────────────────────────────────────────── -->
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <!-- ── Plugins ─────────────────────────────────────────────────────── -->
    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-imu-system"
            name="gz::sim::systems::Imu"/>
    <plugin filename="gz-sim-air-pressure-system"
            name="gz::sim::systems::AirPressure"/>
    <plugin filename="gz-sim-magnetometer-system"
            name="gz::sim::systems::Magnetometer"/>

    <!-- ── Lighting — golden hour / evening ───────────────────────────── -->
    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 500 0 0 0</pose>
      <diffuse>0.95 0.82 0.62 1</diffuse>
      <specular>0.4 0.35 0.2 1</specular>
      <direction>-0.6 0.3 -0.7</direction>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
    </light>

    <light name="ambient_fill" type="directional">
      <pose>0 0 200 0 0 0</pose>
      <diffuse>0.3 0.4 0.5 1</diffuse>
      <specular>0.1 0.1 0.15 1</specular>
      <direction>0.3 -0.2 -0.9</direction>
      <cast_shadows>false</cast_shadows>
    </light>

    <!-- ── Sky ─────────────────────────────────────────────────────────── -->
    <scene>
      <sky>
        <clouds>
          <speed>5</speed>
        </clouds>
      </sky>
      <ambient>0.4 0.4 0.5 1</ambient>
      <background>0.55 0.65 0.75 1</background>
      <shadows>true</shadows>
    </scene>

    <!-- ════════════════════════════════════════════════════════════════
         TERRAIN — Main flat base + hill mounds
         ════════════════════════════════════════════════════════════════ -->

    <!-- Base ground plane (green valley floor) -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="col">
          <geometry><plane><normal>0 0 1</normal><size>500 500</size></plane></geometry>
        </collision>
        <visual name="vis">
          <geometry><plane><normal>0 0 1</normal><size>500 500</size></plane></geometry>
          <material>
            <ambient>0.28 0.42 0.18 1</ambient>
            <diffuse>0.32 0.48 0.20 1</diffuse>
            <specular>0.05 0.07 0.03 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Hill 1 — large central ridge (north area) -->
    <model name="hill_1">
      <static>true</static>
      <pose>0 40 0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>60 40 8</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>60 40 8</size></box></geometry>
          <material>
            <ambient>0.26 0.38 0.16 1</ambient>
            <diffuse>0.30 0.44 0.18 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Hill 1 peak -->
    <model name="hill_1_peak">
      <static>true</static>
      <pose>5 42 8 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>30 20 6</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>30 20 6</size></box></geometry>
          <material>
            <ambient>0.38 0.32 0.24 1</ambient>
            <diffuse>0.42 0.36 0.28 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Hill 2 — east slope -->
    <model name="hill_2">
      <static>true</static>
      <pose>35 -10 0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>40 30 6</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>40 30 6</size></box></geometry>
          <material>
            <ambient>0.25 0.36 0.15 1</ambient>
            <diffuse>0.28 0.40 0.17 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Hill 2 secondary mound -->
    <model name="hill_2b">
      <static>true</static>
      <pose>42 -8 6 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>18 14 5</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>18 14 5</size></box></geometry>
          <material>
            <ambient>0.36 0.30 0.22 1</ambient>
            <diffuse>0.40 0.34 0.26 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Hill 3 — west hump -->
    <model name="hill_3">
      <static>true</static>
      <pose>-30 20 0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>35 25 5</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>35 25 5</size></box></geometry>
          <material>
            <ambient>0.27 0.39 0.17 1</ambient>
            <diffuse>0.31 0.45 0.19 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Hill 3 peak -->
    <model name="hill_3_peak">
      <static>true</static>
      <pose>-32 22 5 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>16 12 4</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>16 12 4</size></box></geometry>
          <material>
            <ambient>0.35 0.29 0.21 1</ambient>
            <diffuse>0.39 0.33 0.25 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Hill 4 — south-east ridge -->
    <model name="hill_4">
      <static>true</static>
      <pose>20 -30 0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>50 20 4</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>50 20 4</size></box></geometry>
          <material>
            <ambient>0.24 0.35 0.14 1</ambient>
            <diffuse>0.27 0.39 0.16 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ════════════════════════════════════════════════════════════════
         TREES — 25 pine trees across hillsides
         Each tree = trunk cylinder + canopy cone approximated by cylinders
         ════════════════════════════════════════════════════════════════ -->

    <!-- Tree macro: trunk + 3 canopy layers -->
    <!-- Tree 1 -->
    <model name="tree_01"><static>true</static><pose>8 35 8 0 0 0</pose>
      <link name="trunk"><visual name="v"><geometry><cylinder><radius>0.18</radius><length>3.5</length></cylinder></geometry><material><ambient>0.28 0.18 0.08 1</ambient><diffuse>0.32 0.20 0.10 1</diffuse></material></visual><collision name="c"><geometry><cylinder><radius>0.18</radius><length>3.5</length></cylinder></geometry></collision></link></model>
    <model name="tree_01_c1"><static>true</static><pose>8 35 10.5 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><cylinder><radius>2.2</radius><length>2.5</length></cylinder></geometry><material><ambient>0.12 0.28 0.10 1</ambient><diffuse>0.14 0.32 0.12 1</diffuse></material></visual></link></model>
    <model name="tree_01_c2"><static>true</static><pose>8 35 12.2 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><cylinder><radius>1.5</radius><length>2.0</length></cylinder></geometry><material><ambient>0.14 0.30 0.12 1</ambient><diffuse>0.16 0.35 0.14 1</diffuse></material></visual></link></model>
    <model name="tree_01_c3"><static>true</static><pose>8 35 13.5 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><cylinder><radius>0.7</radius><length>1.5</length></cylinder></geometry><material><ambient>0.16 0.32 0.14 1</ambient><diffuse>0.18 0.38 0.16 1</diffuse></material></visual></link></model>

    <!-- Tree 2 -->
    <model name="tree_02"><static>true</static><pose>-5 38 8 0 0 0</pose>
      <link name="trunk"><visual name="v"><geometry><cylinder><radius>0.20</radius><length>4.0</length></cylinder></geometry><material><ambient>0.28 0.18 0.08 1</ambient><diffuse>0.32 0.20 0.10 1</diffuse></material></visual><collision name="c"><geometry><cylinder><radius>0.20</radius><length>4.0</length></cylinder></geometry></collision></link></model>
    <model name="tree_02_c1"><static>true</static><pose>-5 38 11.2 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><cylinder><radius>2.5</radius><length>2.8</length></cylinder></geometry><material><ambient>0.10 0.25 0.09 1</ambient><diffuse>0.12 0.29 0.11 1</diffuse></material></visual></link></model>
